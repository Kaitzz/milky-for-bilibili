# ============================================================
# B站 Video Summarizer Bot - 环境变量配置
# 复制此文件为 .env 并填入你的真实值
# ============================================================

# --- B站认证 ---
# 从浏览器登录B站后，F12 -> Application -> Cookies 中获取
BILIBILI_SESSDATA=your_sessdata_here
BILIBILI_BILI_JCT=your_bili_jct_here
BILIBILI_DEDEUSERID=your_dedeuserid_here

# --- AI 总结服务 ---
# 支持 OpenAI 兼容接口（OpenAI / DeepSeek / 本地 Ollama 等）
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=deepseek-chat

# --- Claude（可选，用户评论中提到 Claude 时使用）---
CLAUDE_BASE_URL=https://api.anthropic.com/v1/
CLAUDE_API_KEY=sk-your-claude-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# --- OpenAI（可选，用户评论中提到 ChatGPT/OpenAI 时使用）---
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

# --- Bot 配置 ---
# Bot 在评论区显示的名字
BOT_NAME=总结姬
# 你的B站 UID（用于识别 @提及）
BOT_UID=your_uid_here
# 轮询间隔（秒）
POLL_INTERVAL=30
# 单次回复最大字数
MAX_REPLY_LENGTH=800

# --- 语音识别（可选，无CC字幕时自动转写音频）---
# 默认使用 SiliconFlow（便宜！约 ¥0.01/分钟），也兼容 OpenAI Whisper
WHISPER_ENABLED=true
WHISPER_BASE_URL=https://api.siliconflow.cn/v1
WHISPER_API_KEY=sk-your-siliconflow-key-here
WHISPER_MODEL=FunAudioLLM/SenseVoiceSmall
# 超过此时长（秒）的视频不做语音识别
WHISPER_MAX_DURATION=1200

# --- 邮件笔记功能（可选，用户可 @bot 请求笔记发送到邮箱）---
EMAIL_ENABLED=false
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your-email@qq.com
SMTP_PASSWORD=your-smtp-auth-code
